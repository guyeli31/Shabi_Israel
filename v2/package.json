{
  "name": "shabi-israel-v2",
  "version": "0.1.0-alpha",
  "private": true,
  "type": "module",
  "description": "Shabi Israel chess league stats — clean-slate rebuild (v2).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test tests/visual",
    "test:a11y": "playwright test tests/a11y",
    "test:parity": "node scripts/parity-runner.js",
    "lint": "stylelint \"src/**/*.css\" && eslint \"src/**/*.js\"",
    "lint:fix": "stylelint --fix \"src/**/*.css\" && eslint --fix \"src/**/*.js\"",
    "ci": "npm run lint && npm run test && npm run test:visual",
    "data-sync": "node scripts/data-sync.js",
    "cutover": "bash scripts/migrate-v1-to-v2.sh"
  },
  "devDependencies": {
    "vite": "^5.4.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "eslint": "^9.0.0",
    "vitest": "^2.0.0",
    "@playwright/test": "^1.48.0",
    "axe-core": "^4.10.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "sirv": "^2.0.4"
  }
}
